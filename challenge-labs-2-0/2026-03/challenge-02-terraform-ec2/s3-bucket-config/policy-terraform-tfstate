{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::lucas-meira-terraform-state",
      "Condition": {
        "StringEquals": {
          "s3:prefix": "terraform.tfstate"
        }
      }
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": [
        "arn:aws:s3:::lucas-meira-terraform-state/terraform.tfstate"
      ]
    }
  ]
}
